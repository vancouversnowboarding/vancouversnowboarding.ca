#!/usr/bin/env ruby
# frozen_string_literal: true

require 'date'
require 'fileutils'
require 'json'
require 'optparse'
require 'open3'
require 'tempfile'

STYLE_CAPSULE = <<~TEXT.freeze
  Write a Vancouver Snowboarding Whistler Blackcomb snow report.
  Use Canadian English.
  Use ASCII only.
  Keep it concise: exactly 2 short prose paragraphs.
  Use only facts that are explicitly supported by the provided summary or image labels.
  If a fact is not provided, leave it unsaid.
  Do not invent weather, visibility, hut, or food details.
  Paragraph 1 may cover weather and visibility if provided.
  Paragraph 2 should cover snow quality, busyness, and race-event impacts if provided.
  A caption line and standalone Markdown image line may appear between those paragraphs and do not count as prose paragraphs.
  Each image must be on its own line.
  Any caption or lead-in text should be on a separate line immediately before the image.
  Do not append image markdown to a sentence.
  Use numeric digits for all counts, totals, delays, and ratings.
  Do not mention skiing.
  Do not repeat the report's own date in prose.
  Do not include front matter or a title.
  Do not include the rating line; the script will add it.
  If you mention another day, use markdown links to the matching report path.
TEXT

DEFAULT_MODEL = 'gpt-5.1-codex-mini'
DEFAULT_REFERENCE_DATE = '2025-04-18'
REPORT_GLOB = '_posts/*-whistler-blackcomb-snow-report.md'
TMP_IMAGE_GLOB = '/tmp/*.{jpg,jpeg,JPG,png,PNG}'
IMAGE_EXTENSIONS = '.{jpg,jpeg,JPG,png,PNG}'

options = {
  model: DEFAULT_MODEL,
  reference_date: DEFAULT_REFERENCE_DATE
}

parser = OptionParser.new do |opts|
  opts.banner = 'Usage: bin/snow-report-create --summary "rate 4, partially sunny & cloudy, not busy" [--date YYYY-MM-DD]'
  opts.on('--date DATE', 'Report date in YYYY-MM-DD format; defaults to today in Vancouver') do |value|
    options[:date] = value
  end
  opts.on('--summary TEXT', 'Short human summary of the day; must include a rating like "rate 4"') do |value|
    options[:summary] = value
  end
  opts.on('--model MODEL', "Codex model to use (default: #{DEFAULT_MODEL})") do |value|
    options[:model] = value
  end
  opts.on('--reference-date DATE', "Reference report date for style sampling (default: #{DEFAULT_REFERENCE_DATE})") do |value|
    options[:reference_date] = value
  end
  opts.on('--dry-run', 'Print the planned actions without writing files') do
    options[:dry_run] = true
  end
  opts.on('-h', '--help', 'Show help') do
    puts opts
    exit 0
  end
end

def abort_with_usage(parser, message)
  warn(message)
  warn(parser.to_s)
  exit 1
end

def git_root
  stdout, status = Open3.capture2('git', 'rev-parse', '--show-toplevel')
  return stdout.strip if status.success?

  abort('snow-report create: could not determine git root')
end

def parse_date(value, parser)
  Date.strptime(value, '%Y-%m-%d')
rescue ArgumentError
  abort_with_usage(parser, "--date must be YYYY-MM-DD, got #{value.inspect}")
end

def parse_rating(summary, parser)
  match = summary.match(/\b(?:rate|rating)\s*:?\s*([1-5])(?:\s*\/\s*5)?\b/i)
  return match[1].to_i if match

  abort_with_usage(parser, '--summary must include a rating like "rate 4"')
end

def stars_for_rating(rating)
  '★' * rating + '☆' * (5 - rating)
end

def reference_path(root, reference_date)
  File.join(root, '_posts', "#{reference_date}-#{reference_date}-whistler-blackcomb-snow-report.md")
end

def body_from_reference(path)
  content = File.read(path)
  body = content.split(/\A---\s*\n.*?\n---\s*\n/m, 2).last || ''
  paragraphs = body.split(/\n{2,}/).map(&:strip).reject(&:empty?)
  paragraphs.take(2).join("\n\n")
end

def normalize_model_body(text)
  body = text.to_s.strip
  body = body.sub(/\A```(?:markdown)?\s*\n/, '')
  body = body.sub(/\n```\z/, '')
  body.strip
end

def json_schema_tempfile(schema)
  file = Tempfile.new(['snow-report-schema', '.json'])
  file.write(JSON.pretty_generate(schema))
  file.close
  file
end

def parse_structured_response!(raw, context)
  body = raw.to_s.strip
  abort("snow-report create: #{context} returned empty output") if body.empty?

  JSON.parse(body)
rescue JSON::ParserError => e
  abort("snow-report create: #{context} returned invalid JSON: #{e.message}")
end

def local_time_string(date)
  Time.local(date.year, date.month, date.day, 14, 10, 0).strftime('%Y-%m-%dT%H:%M:%S%:z')
end

def image_glob_for(date_string)
  "assets/images/#{date_string}-*#{IMAGE_EXTENSIONS}"
end

def asset_path_for_prompt(path)
  relpath = path.sub(%r{\A\./}, '')
  relpath.start_with?('/') ? relpath : "/#{relpath}"
end

def normalize_image_label(first, second)
  if first.to_s.match?(/\A\d{4}-\d{2}-\d{2}\z/)
    date_string = first
    path = second
  else
    path = first
    date_string = second
  end
  basename = File.basename(path, File.extname(path))
  label = basename.sub(/\A#{Regexp.escape(date_string)}-/, '')
  label = label.tr('_-', ' ')
  label.gsub(/\s+/, ' ').strip
end

def image_metadata_for(date_string, path)
  {
    'path' => asset_path_for_prompt(path),
    'label' => normalize_image_label(date_string, path)
  }
end

def discover_image_metadata(date_string)
  all_images = Dir.glob(image_glob_for(date_string)).sort_by { |path| [path.downcase, path] }
  feature_image = all_images.find { |path| File.basename(path).match?(/\A#{Regexp.escape(date_string)}-feature\./) }
  body_candidates = all_images.reject { |path| path == feature_image }.map { |path| image_metadata_for(date_string, path) }

  {
    feature_image: feature_image && image_metadata_for(date_string, feature_image),
    body_candidates: body_candidates
  }
end

def collect_image_metadata(date_string)
  discovered = discover_image_metadata(date_string)
  {
    feature_image: discovered[:feature_image] && discovered[:feature_image].fetch('path').delete_prefix('/'),
    body_candidates: discovered[:body_candidates].map do |image|
      { path: image.fetch('path'), label: image.fetch('label') }
    end
  }
end

def image_value(image, key)
  image[key] || image[key.to_s]
end

MARKDOWN_IMAGE_ANYWHERE_REGEX = /!\[[^\]]*\]\(([^)]+)\)/
MARKDOWN_IMAGE_LINE_REGEX = /\A\s*!\[[^\]]*\]\(([^)]+)\)\s*\z/
FACT_CATEGORIES = {
  weather: {
    sunny: /\b(?:sunny|sun|bright|clear skies?)\b/i,
    cloudy: /\b(?:cloudy|cloud|grey skies?|gray skies?|overcast)\b/i,
    rainy: /\b(?:rain|rainy|drizzle|drizzly|wet)\b/i,
    snowy: /\b(?:snow|snowing|flurr(?:y|ies))\b/i,
    foggy: /\b(?:fog|foggy|mist|misty)\b/i
  },
  visibility: {
    good: /\b(?:visibility (?:was |stayed |kept )?(?:good|great|clear)|vis(?:ibility)? (?:was |stayed |kept )?(?:good|great|clear)|crisp visibility|clear visibility)\b/i,
    poor: /\b(?:visibility (?:was |stayed |kept )?(?:poor|bad|low|limited)|vis(?:ibility)? (?:was |stayed |kept )?(?:poor|bad|low|limited)|flat light|whiteout)\b/i
  },
  hut_food: {
    hut: /\b(?:hut|lodge|chalet|cafeteria|garage|deck)\b/i,
    food: /\b(?:bannock|broth|cinnamon bun|soup|coffee|tea|sandwich)\b/i
  }
}.freeze

def normalize_markdown_image_target(target)
  path = target.to_s.strip
  path = path.sub(/\A<([^>]+)>\z/, '\1')
  path.split(/\s+/, 2).first
end

def prompt_image_metadata(image_metadata: nil, feature_image: nil, body_candidates: nil)
  if image_metadata
    feature_path = image_metadata[:feature_image] || image_metadata['feature_image']
    candidates = image_metadata[:body_candidates] || image_metadata['body_candidates'] || []
  else
    feature_path = feature_image && (feature_image['path'] || feature_image[:path])
    candidates = body_candidates || []
  end

  {
    feature_image: feature_path,
    body_candidates: candidates.map do |image|
      { path: image_value(image, :path), label: image_value(image, :label) }
    end
  }
end

def image_metadata_prompt(image_metadata: nil, feature_image: nil, body_candidates: nil)
  metadata = prompt_image_metadata(image_metadata: image_metadata, feature_image: feature_image, body_candidates: body_candidates)
  lines = []
  lines << 'Feature image:'
  if metadata[:feature_image]
    lines << "- path: #{metadata[:feature_image]}"
  else
    lines << '- none'
  end
  lines << ''
  lines << 'Body candidate images:'
  if metadata[:body_candidates].empty?
    lines << '- none'
  else
    metadata[:body_candidates].each do |image|
      lines << "- path: #{image.fetch(:path)}"
      lines << "  label: #{image.fetch(:label)}"
    end
  end
  lines.join("\n")
end

def markdown_image_paths(body)
  body.to_s.scan(MARKDOWN_IMAGE_ANYWHERE_REGEX).flatten.map do |target|
    path = normalize_markdown_image_target(target)
    next unless path

    path.start_with?('assets/images/') ? "/#{path}" : path
  end.compact
end

def markdown_image_paths_on_own_lines(body)
  body.to_s.each_line.filter_map do |line|
    match = line.match(MARKDOWN_IMAGE_LINE_REGEX)
    next unless match

    path = normalize_markdown_image_target(match[1])
    next unless path

    path.start_with?('assets/images/') ? "/#{path}" : path
  end
end

def validate_body_image_links!(body:, image_metadata:)
  metadata = prompt_image_metadata(image_metadata: image_metadata)
  referenced_paths = markdown_image_paths(body)
  standalone_paths = markdown_image_paths_on_own_lines(body)
  raise 'snow-report create: markdown images must be on their own line' unless referenced_paths == standalone_paths

  referenced_paths = standalone_paths.select { |path| path.start_with?('/assets/images/') }
  allowed_paths = metadata[:body_candidates].map { |image| image.fetch(:path) }
  feature_path = metadata[:feature_image] && asset_path_for_prompt(metadata[:feature_image])

  raise 'snow-report create: body must not use the feature image' if feature_path && referenced_paths.include?(feature_path)

  unknown_paths = referenced_paths.reject { |path| allowed_paths.include?(path) || path == feature_path }
  raise "snow-report create: body used unknown image path #{unknown_paths.first}" unless unknown_paths.empty?

  if !allowed_paths.empty? && (referenced_paths & allowed_paths).empty?
    raise 'snow-report create: body must use at least 1 body image'
  end
end

def validate_body_image_usage!(body:, feature_image:, body_candidates:)
  image_metadata = {
    feature_image: feature_image && feature_image.fetch('path').delete_prefix('/'),
    body_candidates: body_candidates.map { |image| { path: image.fetch('path'), label: image.fetch('label') } }
  }
  validate_body_image_links!(body: body, image_metadata: image_metadata)
rescue RuntimeError => e
  abort(e.message)
end

def extract_fact_categories(text)
  FACT_CATEGORIES.transform_values do |patterns|
    patterns.each_with_object([]) do |(name, regex), matches|
      matches << name if text.to_s.match?(regex)
    end
  end.transform_values(&:uniq)
end

def validate_body_facts!(body:, summary:)
  summary_facts = extract_fact_categories(summary)
  body_facts = extract_fact_categories(body)

  unsupported = []
  body_facts.each do |category, values|
    next if values.empty?

    supported_values = summary_facts.fetch(category)
    if supported_values.empty?
      unsupported << "#{category}=#{values.join(',')}"
      next
    end

    extra_values = values - supported_values
    unsupported << "#{category}=#{extra_values.join(',')}" unless extra_values.empty?
  end

  return if unsupported.empty?

  raise "snow-report create: body includes unsupported factual detail(s): #{unsupported.join('; ')}"
end

def ruby_prompt(reference_excerpt:, date:, summary:, rating:, stars:, image_metadata: nil, feature_image: nil, body_candidates: nil)
  <<~PROMPT
    Do not inspect files or run commands. Use only the text in this prompt.

    #{STYLE_CAPSULE}

    Image rules:
    * If body candidate images exist, include at least 1 in the body.
    * Never use the feature image inside the body.
    * Place each image on its own line, with any caption or lead-in text on a separate line immediately before it.
    * Mention weather, visibility, hut, or food only when they are explicitly supported by the summary or image labels.
    * If the summary does not provide a detail, omit it instead of guessing.
    * Paragraph 1 may cover weather and visibility when provided.
    * Paragraph 2 should cover snow quality, busyness, and race-event impacts when provided.
    * A caption line and standalone Markdown image line may appear between the prose paragraphs and do not count as prose paragraphs.
    * Do not append image markdown to a sentence or dump images as a tail gallery.

    Facts:
    * date: #{date}
    * summary: #{summary}
    * rating: #{rating}/5 #{stars}

    Images:
    #{image_metadata_prompt(image_metadata: image_metadata, feature_image: feature_image, body_candidates: body_candidates)}

    Reference sample:
    #{reference_excerpt}

    Return JSON with a single key: body.
  PROMPT
end

def review_prompt(reference_excerpt:, draft_body:, date:, summary:, rating:, stars:, image_metadata: nil, feature_image: nil, body_candidates: nil)
  <<~PROMPT
    Do not inspect files or run commands. Use only the text in this prompt.

    #{STYLE_CAPSULE}

    Check this draft against the facts and style.
    If it is good, reply with JSON: {"verdict":"pass","body":""}.
    If it needs changes, reply with JSON: {"verdict":"fix","body":"..."}.
    Reject any unsupported factual detail that is not explicitly supported by the summary or image labels.
    Reject any draft that repeats the report's own date in prose.
    If body candidate images exist, include at least 1 in the body.
    Never use the feature image inside the body.
    Place each image on its own line, with any caption or lead-in text on a separate line immediately before it.
    Mention weather, visibility, hut, or food only when they are explicitly supported by the summary or image labels.
    If the summary does not provide a detail, omit it instead of guessing.
    Paragraph 1 may cover weather and visibility when provided.
    Paragraph 2 should cover snow quality, busyness, and race-event impacts when provided.
    A caption line and standalone Markdown image line may appear between the prose paragraphs and do not count as prose paragraphs.
    Do not append image markdown to a sentence or dump images as a tail gallery.

    Facts:
    * date: #{date}
    * summary: #{summary}
    * rating: #{rating}/5 #{stars}

    Images:
    #{image_metadata_prompt(image_metadata: image_metadata, feature_image: feature_image, body_candidates: body_candidates)}

    Reference sample:
    #{reference_excerpt}

    Draft:
    #{draft_body}
  PROMPT
end

def generate_reviewed_body(root:, model:, reference_excerpt:, date_string:, summary:, rating:, stars:, image_metadata:, codex_runner: nil)
  codex_runner ||= lambda { |args| run_codex_structured(**args) }

  prompt = ruby_prompt(
    reference_excerpt: reference_excerpt,
    date: date_string,
    summary: summary,
    rating: rating,
    stars: stars,
    image_metadata: image_metadata
  )
  draft_response = codex_runner.call(
    root: root,
    model: model,
    prompt: prompt,
    schema: draft_schema,
    context: 'draft generation'
  )
  draft_body = normalize_model_body(draft_response.fetch('body'))

  review = review_prompt(
    reference_excerpt: reference_excerpt,
    draft_body: draft_body,
    date: date_string,
    summary: summary,
    rating: rating,
    stars: stars,
    image_metadata: image_metadata
  )
  review_result = codex_runner.call(
    root: root,
    model: model,
    prompt: review,
    schema: review_schema,
    context: 'review'
  )
  if review_result.fetch('verdict') == 'fix'
    fixed_body = review_result['body'].to_s
    abort('snow-report create: review requested a fix but returned no body') if fixed_body.strip.empty?
    draft_body = normalize_model_body(fixed_body)
    second_review = codex_runner.call(
      root: root,
      model: model,
      prompt: review_prompt(
        reference_excerpt: reference_excerpt,
        draft_body: draft_body,
        date: date_string,
        summary: summary,
        rating: rating,
        stars: stars,
        image_metadata: image_metadata
      ),
      schema: review_schema,
      context: 'review retry'
    )
    if second_review.fetch('verdict') != 'pass'
      puts second_review.inspect
      abort('snow-report create: review still failed after one retry')
    end
  end

  validate_body_image_links!(body: draft_body, image_metadata: image_metadata)
  validate_body_facts!(body: draft_body, summary: summary)
  draft_body
end

def draft_schema
  {
    'type' => 'object',
    'additionalProperties' => false,
    'required' => ['body'],
    'properties' => {
      'body' => { 'type' => 'string' }
    }
  }
end

def review_schema
  {
    'type' => 'object',
    'additionalProperties' => false,
    'required' => ['verdict', 'body'],
    'properties' => {
      'verdict' => { 'type' => 'string', 'enum' => ['pass', 'fix'] },
      'body' => { 'type' => 'string' }
    }
  }
end

def run_codex_structured(root:, model:, prompt:, schema:, context:)
  out = Tempfile.new(['snow-report-create', '.txt'])
  out.close
  schema_file = json_schema_tempfile(schema)
  cmd = [
    'codex', 'exec',
    '--ephemeral',
    '--full-auto',
    '--model', model,
    '--cd', root,
    '--output-schema', schema_file.path,
    '--output-last-message', out.path,
    '-'
  ]
  stdout, stderr, status = Open3.capture3(*cmd, stdin_data: prompt)
  unless status.success?
    warn stdout unless stdout.empty?
    warn stderr unless stderr.empty?
    abort("snow-report create: codex exec failed with status #{status.exitstatus}")
  end

  parse_structured_response!(File.read(out.path), context)
ensure
  out.unlink if out && out.path && File.exist?(out.path)
  schema_file.unlink if schema_file && schema_file.path && File.exist?(schema_file.path)
end

def update_featured_flags(root:, report_date:)
  reports = Dir.glob(File.join(root, REPORT_GLOB)).sort
  reports.each do |path|
    basename = File.basename(path)
    existing_date = basename[0, 10]
    next if existing_date >= report_date

    content = File.read(path)
    next unless content.include?('featured: true')

    updated = content.sub(/^featured:\s*true\s*$/m, 'featured: false')
    next if updated == content

    File.write(path, updated)
  end
end

def run!(options, parser)
  root = git_root
  Dir.chdir(root)

  date = parse_date(options[:date] || Date.today.strftime('%Y-%m-%d'), parser)
  date_string = date.strftime('%Y-%m-%d')
  report_relpath = "_posts/#{date_string}-#{date_string}-whistler-blackcomb-snow-report.md"
  report_path = File.join(root, report_relpath)
  rating = parse_rating(options[:summary], parser)
  stars = stars_for_rating(rating)
  reference_file = reference_path(root, options[:reference_date])

  abort("snow-report create: no /tmp images found; put the source images in /tmp first") if Dir.glob(TMP_IMAGE_GLOB).empty?
  abort("snow-report create: reference report not found at #{reference_file}") unless File.exist?(reference_file)
  abort("snow-report create: report already exists at #{report_path}") if File.exist?(report_path)

  puts "snow-report create: processing /tmp images for #{date_string}"
  puts "snow-report create: using reference #{reference_file}"

  if options[:dry_run]
    puts 'snow-report create: dry run only'
    puts "snow-report create: would write #{report_path}"
    puts "snow-report create: would use model #{options[:model]}"
    exit 0
  end

  system('./image.sh', date_string) or abort('snow-report create: image.sh failed')
  image_metadata = collect_image_metadata(date_string)
  feature_image = image_metadata[:feature_image]
  abort("snow-report create: feature image not found for #{date_string}") unless feature_image

  reference_excerpt = body_from_reference(reference_file)

  puts 'waiting for codex...'
  draft_body = generate_reviewed_body(
    root: root,
    model: options[:model],
    reference_excerpt: reference_excerpt,
    date_string: date_string,
    summary: options[:summary],
    rating: rating,
    stars: stars,
    image_metadata: image_metadata
  )

  front_matter = <<~FRONT
    ---
    layout: post
    title: #{date_string} Whistler Blackcomb snow report
    date: "#{local_time_string(date)}"
    tag: Whistler Blackcomb
    image: #{feature_image || "assets/images/#{date_string}-feature.jpg"}
    featured: true
    ---
  FRONT

  body = draft_body.strip
  body = "#{body}\n\nOverall rate: #{rating}/5 #{stars}" unless body.match?(/Overall rate:/)

  File.write(report_path, "#{front_matter}\n#{body}\n")
  update_featured_flags(root: root, report_date: date_string)

  puts "snow-report create: wrote #{report_path}"
  puts "snow-report create: feature image #{feature_image || "assets/images/#{date_string}-feature.jpg"}"
  puts 'snow-report create: running lint'
  system('bin/snow-report-lint', '--auto-correct') or abort('snow-report create: lint failed')
  puts 'snow-report create: running review'
  system('bin/snow-report-review') or abort('snow-report create: review failed')

  stage_files = Dir.glob(File.join('assets/images', "#{date_string}-*"))
  stage_files << report_relpath
  stage_files.uniq!

  puts "snow-report create: staging #{stage_files.size} file(s)"
  system('git', 'add', '--', *stage_files) or abort('snow-report create: git add failed')

  commit_message = "Add #{date_string} Whistler Blackcomb snow report"
  puts "snow-report create: committing with #{commit_message.inspect}"
  system('git', 'commit', '-am', commit_message) or abort('snow-report create: git commit failed')

  puts 'snow-report create: done'
end

if __FILE__ == $PROGRAM_NAME
  parser.parse!(ARGV)
  abort_with_usage(parser, '--summary is required') unless options[:summary]
  ENV['TZ'] = 'America/Vancouver'
  run!(options, parser)
end
