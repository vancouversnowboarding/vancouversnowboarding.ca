#!/usr/bin/env ruby

require 'date'

UNICODE_QUOTES = {
  '‘' => 'left single quote',
  '’' => 'right single quote',
  '“' => 'left double quote',
  '”' => 'right double quote'
}.freeze

UNICODE_REPLACEMENTS = {
  '‘' => "'",
  '’' => "'",
  '“' => '"',
  '”' => '"'
}.freeze

AUTO_CORRECT_FLAGS = %w[--auto-correct --autocorrect --fix].freeze

auto_correct = ARGV.any? { |flag| AUTO_CORRECT_FLAGS.include?(flag) }
ARGV.reject! { |arg| AUTO_CORRECT_FLAGS.include?(arg) }

MONTH_NUMBERS = {
  'january' => 1,
  'february' => 2,
  'march' => 3,
  'april' => 4,
  'may' => 5,
  'june' => 6,
  'july' => 7,
  'august' => 8,
  'september' => 9,
  'october' => 10,
  'november' => 11,
  'december' => 12
}.freeze

DATE_MENTION_REGEX = /(Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday),\s+([A-Za-z]+)\s+(\d{1,2})/i

paths = Dir.glob('_posts/*-snow-report*.md').sort
paths.select! do |path|
  date_part = File.basename(path)[0, 10]
  begin
    Date.parse(date_part) >= Date.parse('2026-01-01')
  rescue ArgumentError
    false
  end
end

if paths.empty?
  warn 'snow-report lint: no 2026+ snow-report posts were found to check.'
  exit 0
end

unicode_re = Regexp.union(UNICODE_QUOTES.keys)
problems = []
corrections = []

paths.each do |path|
  date_part = File.basename(path)[0, 10]
  report_date = Date.parse(date_part) rescue next
  lines = File.readlines(path, chomp: true)
  file_modified = false
  in_front_matter = true
  self_date_regex = /\b#{Regexp.escape(date_part)}\b/
  lines.each_with_index do |line, idx|
    current_line = line.dup
    number = idx + 1

    if in_front_matter
      in_front_matter = false if idx.positive? && line == '---'
      next
    end

    if line =~ /^\s*-\s+/           # bullet lines must use '*'
      if auto_correct
        current_line = current_line.sub(/^(\s*)-\s+/, '\1* ')
        file_modified = true
        corrections << "#{path}:#{number}: auto-corrected hyphen bullet to '*'"
      else
        problems << "#{path}:#{number}: hyphen bullet found; use '*' for markdown lists."
      end
    end

    line.scan(DATE_MENTION_REGEX) do |day_name, month_name, day_number|
      mention_month = MONTH_NUMBERS[month_name.downcase]
      next if !mention_month
      year = report_date.year
      year -= 1 if mention_month > report_date.month + 1
      mention_day = day_number.to_i
      next if mention_day.zero? || mention_day > 31
      begin
        mention_date = Date.new(year, mention_month, mention_day)
      rescue RangeError
        next
      end
      target_fragment = "/#{mention_date.strftime('%Y-%m-%d')}-"
      next if line.include?(target_fragment)
      problems << "#{path}:#{number}: #{day_name}, #{month_name} #{mention_day} reference needs a link to /#{mention_date.strftime('%Y-%m-%d')}-whistler-blackcomb-snow-report.md."
    end

    line_without_links = line.gsub(/\[[^\]]*\]\([^)]+\)/, '')
    if line_without_links.match?(self_date_regex)
      problems << "#{path}:#{number}: body must not repeat its own report date (found #{date_part}); rewrite it without the date."
    end

    unicode_found = false
    line.scan(unicode_re) do |quote_char|
      label = UNICODE_QUOTES[quote_char]
      unicode_found = true
      if auto_correct
        corrections << "#{path}:#{number}: auto-corrected #{label} #{quote_char.inspect}"
      else
        problems << "#{path}:#{number}: unicode quote #{quote_char.inspect} (#{label}) detected; use ASCII quotes."
      end
    end

    if auto_correct && unicode_found
      current_line = current_line.gsub(unicode_re) { |quote| UNICODE_REPLACEMENTS[quote] || quote }
      file_modified = true
    end

    if auto_correct && current_line != line
      lines[idx] = current_line
    end
  end

  if auto_correct && file_modified
    File.write(path, lines.join("\n") + "\n")
  end
end

if !corrections.empty?
  puts "snow-report lint: auto-corrected #{corrections.size} issue(s):"
  corrections.each { |correction| puts "  #{correction}" }
end

if problems.empty?
  puts 'snow-report lint: ok'
  exit 0
end

puts "snow-report lint: #{problems.size} issue(s) detected:"
problems.each { |problem| puts "  #{problem}" }
exit 1
